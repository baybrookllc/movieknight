# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_ACCESS_TOKEN=<supabase-access-token>

# ─── Third-party API keys (used in Supabase edge functions, not in client) ───
TMDB_API_KEY=<tmdb-api-key>
OPENAI_API_KEY=<openai-api-key>
DTDD_API_KEY=<dtdd-api-key>

# ─── AI assistant (used in /api/claude/ask server route) ─────────────────────
ANTHROPIC_API_KEY=<anthropic-api-key>

# ─── Analytics ───────────────────────────────────────────────────────────────
# PostHog — deep product / event analytics
# Get your key at https://posthog.com → Project Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Umami — cookieless, GDPR-compliant traffic analytics
# Get your website ID from your Umami dashboard after adding the site
NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is
NEXT_PUBLIC_UMAMI_PIXEL_URL=https://cloud.umami.is/p/<short-id>
